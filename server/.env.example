# ──────────────────────────────────────────────
#  Server Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to git.
# ──────────────────────────────────────────────

# Server port
PORT=5001

# Client origin (for CORS)
CLIENT_ORIGIN=http://127.0.0.1:5173

# JWT secret for officer authentication (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Officer login credentials
OFFICER_EMAIL=admin@example.com
OFFICER_PASSWORD=change-this-password

# PostgreSQL connection (leave empty for Supabase-only mode)
DATABASE_URL=
DATABASE_SSL=true

# Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_REPORTS_TABLE=reports
SUPABASE_VIDEOS_BUCKET=noise-report-videos
