# ──────────────────────────────────────────────
#  Client Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and update if needed.
#  In development, Vite proxies /api to the server,
#  so this can be left empty.
# ──────────────────────────────────────────────

# API base URL (leave empty if using Vite proxy in dev)
VITE_API_URL=
